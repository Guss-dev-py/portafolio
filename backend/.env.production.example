# ============================================================
# Variables de entorno de producción — backend
# Copiar este archivo como .env.production y completar los valores
# ============================================================

# Conexión a PostgreSQL
# Si usás docker-compose.postgres.yml, el host es "postgres" (nombre del servicio)
# Si usás PostgreSQL del host, usá "host.docker.internal" o la IP del servidor
DATABASE_URL=postgresql://portfolio_user:tu_password@postgres:5432/portfolio

# Secreto JWT — generar con: openssl rand -hex 32
# Debe tener al menos 32 caracteres
JWT_SECRET=

# Credenciales del panel de administración
ADMIN_USERNAME=admin

# Hash bcrypt de la contraseña del admin
# Generar con: node -e "const b=require('bcrypt');b.hash('tu_password',10).then(console.log)"
ADMIN_PASSWORD_HASH=

# Puerto en el que escucha el backend dentro del contenedor
PORT=3000

# Dominio exacto del frontend en producción (sin trailing slash)
# Usado para CORS — no usar comodines
CORS_ORIGIN=https://freire.ucielbustamante.com

# API key de Resend para envío de emails de notificación
# Obtener en: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
