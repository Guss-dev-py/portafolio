# ============================================================
# Variables de entorno — copiar como .env y completar los valores
# NO commitear el archivo .env
# ============================================================

# ── Puertos ──────────────────────────────────────────────────
FRONTEND_PORT=8080
BACKEND_PORT=3001
POSTGRES_PORT=5432

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_PASSWORD=tu_password_postgres

# ── Backend ───────────────────────────────────────────────────
# Si usás el servicio postgres del compose, el host es "postgres"
DATABASE_URL=postgresql://portfolio_user:tu_password_postgres@postgres:5432/portfolio

# Generar con: openssl rand -hex 32
JWT_SECRET=

# Credenciales del panel admin
ADMIN_USERNAME=tu-usuario-admin

# Generar con: node -e "const b=require('bcrypt');b.hash('tu_password',12).then(console.log)"
# En el archivo .env, escapar los $ del hash como $$: $$2b$$12$$...
ADMIN_PASSWORD_HASH=

# Dominio del frontend en producción (sin trailing slash)
CORS_ORIGIN=https://tu-dominio.com

# API key de Resend — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
